# Linkumori Extension Build Ignore File
# Files and directories to ignore during web-ext operations

# Development files
*.log
*.tmp
.DS_Store
Thumbs.db

# Dependencies
node_modules/**
npm-debug.log*
package-lock.json
package.json

# Version Control
.git/**
.svn/**

# IDEs
.vscode/**
.idea/**
*.swp
*~

# Build Output
web-ext-artifacts/**
build/**
dist/**
CHANGELOG.md
docs/**
# Assets & Fonts (sources only, keep compiled)
svg/**
Old-Country-Nobility/Old-Country-Nobility.sfd

# Data Files (keep bundled LZ4, exclude source/config)
data/linkumori-clearurls.json
data/url-config.json
# Build Tools
.build-ignore
linkumori-cli-tool.js
scripts/**
Template.md
COMMIT_HISTORY.md

# Environment
.env
.env.local

# Testing
test/**
tests/**
tests/regression-suite.json
coverage/**
