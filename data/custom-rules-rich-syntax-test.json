{
  "providers": {
    "rich-syntax-demo": {
      "urlPattern": "^https?:\\/\\/example\\.com\\/rich-demo(?:[/?#]|$)",
      "rules": [
        "utm_source",
        {
          "matchPattern": "token",
          "replacePattern": "clean-§1§",
          "active": true
        }
      ],
      "rawRules": [
        {
          "matchPattern": "wrapped=([^&#]+)",
          "replacePattern": "clean=§1§",
          "active": true
        }
      ],
      "redirections": [
        {
          "matchPattern": "^https?:\\/\\/example\\.com\\/rich-demo\\/redirect\\?url=(.+)$",
          "replacePattern": "§1§",
          "preprocessors": [
            {
              "type": "doubleUrlDecode",
              "inputs": [1]
            }
          ],
          "active": true
        }
      ]
    }
  }
}
